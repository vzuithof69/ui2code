# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Output files
output/*.txt
output/*.json
output/*.py

# Runtime logs (do not track in git)
logs/*.log
logs/latest-error.log

# Keep logs directory structure
!logs/.gitkeep
